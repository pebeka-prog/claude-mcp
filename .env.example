# URL de ton site Ghost (sans slash final)
GHOST_URL=https://your-site.ghost.io

# Staff Access Token Ghost : Ghost Admin → Integrations → Add custom integration
# Format : id:secret  (ex: 64f3a1b2c3d4e5f6a7b8c9d0:abc123def456...)
GHOST_ADMIN_KEY=your_key_id:your_key_secret

# fal.ai API key — requis pour generate_post_image (Flux Pro)
# https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here
